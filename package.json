{
  "name": "your-own-personal-dj",
  "version": "1.0.0",
  "description": "A local DJ app that uses Essentia.js audio analysis to play music matching your mood.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . \"Your Own Personal DJ\" --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "dependencies": {
    "essentia.js": "^0.1.3",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^42.2.0"
  },
  "keywords": [
    "music",
    "dj",
    "essentia",
    "audio-analysis",
    "bpm",
    "key-detection",
    "electron"
  ],
  "author": "Shane W Watson",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.12.0"
  }
}
