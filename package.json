{
  "name": "your-own-personal-dj",
  "version": "2.0.0",
  "description": "A local DJ app that uses Essentia.js audio analysis to play music matching your mood.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . \"Your Own Personal DJ\" --platform=win32 --arch=x64 --out=dist --overwrite --asar.unpack=\"**/node_modules/{node-llama-cpp,@node-llama-cpp}/**\"",
    "lint": "eslint main.js preload.js renderer.js audio-renderer.js audio-analysis-worker.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "essentia.js": "^0.1.3",
    "music-metadata": "^11.13.0",
    "node-id3": "^0.2.9",
    "node-llama-cpp": "^3.19.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@eslint/js": "^10.0.1",
    "electron": "^42.5.2",
    "eslint": "^10.6.0"
  },
  "keywords": [
    "music",
    "dj",
    "essentia",
    "audio-analysis",
    "bpm",
    "key-detection",
    "electron"
  ],
  "author": "Shane W Watson",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=22.12.0"
  }
}
