  "description": "A local DJ app that uses local AI to play music matching your mood.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . \"Your Own Personal DJ\" --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "dependencies": {
